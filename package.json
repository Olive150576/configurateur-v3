{
  "name": "configurateur-v3",
  "version": "1.0.20",
  "description": "Configurateur de devis mobilier",
  "main": "main/index.js",
  "author": "Olive150576",
  "license": "ISC",
  "type": "commonjs",
  "scripts": {
    "start": "node start.js",
    "dev": "node start.js --dev",
    "rebuild": "electron-rebuild",
    "dist": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --x64",
    "release": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --x64 --publish always"
  },
  "keywords": [],
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "better-sqlite3": "^12.8.0",
    "electron-updater": "^6.3.9",
    "qrcode": "^1.5.4"
  },
  "build": {
    "appId": "com.olive.configurateur-v3",
    "productName": "Configurateur V3",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Configurateur V3",
      "artifactName": "${productName}-Setup-${version}.exe",
      "deleteAppDataOnUninstall": false
    },
    "npmRebuild": true,
    "nodeGypRebuild": false,
    "publish": {
      "provider": "github",
      "owner": "Olive150576",
      "repo": "configurateur-v3",
      "releaseType": "release"
    }
  }
}
